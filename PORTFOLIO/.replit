modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["openssl", "postgresql", "unzipNLS"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "run_oi_script"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[workflows.workflow]]
name = "run_oi_script"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python oi.py"

[[workflows.workflow]]
name = "Dev"
author = 42789630
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd portfolio && npm run dev -- --host 0.0.0.0 --port 5000"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173
exposeLocalhost = true
